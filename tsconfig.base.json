{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@commandui/domain": ["packages/domain/src/index.ts"],
      "@commandui/api-contract": ["packages/api-contract/src/index.ts"],
      "@commandui/state": ["packages/state/src/index.ts"],
      "@commandui/ui": ["packages/ui/src/index.ts"]
    }
  }
}
